{
  "graph_id": "alpha-agent-main-v1",
  "version": "2026.4",
  "nodes": {
    "triage": {
      "description": "사용자의 요청을 분석하고 적절한 노드로 라우팅",
      "on_entry": "save_checkpoint"
    },
    "planner": {
      "description": "실행을 위한 단계별 계획 수립 및 도구 선택",
      "on_entry": "save_checkpoint"
    },
    "recursive_research": {
      "description": "Karpathy 루프: 목표 달성을 위한 무한 정보 탐색 및 자기 진화",
      "on_entry": "save_checkpoint",
      "on_success": "planner"
    },
    "executor": {
      "description": "MCP 도구 호출 및 실제 작업 수행",
      "on_entry": "save_checkpoint",
      "on_error": "recovery_node"
    },
    "refinement_review": {
      "description": "3대 페르소나(비판가, 완벽주의자, 천재)의 다단계 검토",
      "on_entry": "save_checkpoint"
    },
    "scoring_engine": {
      "description": "피드백을 수치화하여 신뢰 점수(Trust Score) 산출",
      "on_entry": "calculate_score"
    },
    "recovery_node": {
      "description": "오류 발생 시 원인 분석 및 체크포인트 복구",
      "on_entry": "load_latest_checkpoint"
    }
  },
  "edges": [
    { "from": "triage", "to": "recursive_research", "condition": "needs_deep_research" },
    { "from": "recursive_research", "to": "planner", "condition": "research_complete" },
    { "from": "triage", "to": "planner", "condition": "needs_planning" },
    { "from": "planner", "to": "executor", "condition": "plan_ready" },
    { "from": "executor", "to": "refinement_review", "condition": "execution_complete" },
    { "from": "refinement_review", "to": "scoring_engine", "condition": "review_complete" },
    { "from": "scoring_engine", "to": "end", "condition": "trust_score_gte_9_9" },
    { "from": "scoring_engine", "to": "planner", "condition": "trust_score_lt_9_9" },
    { "from": "executor", "to": "recovery_node", "condition": "runtime_error" },
    { "from": "recovery_node", "to": "executor", "condition": "fix_applied" }
  ],
  "checkpoint_policy": {
    "persistence": "file_system",
    "directory": "core/orchestration/graph/checkpoints/",
    "max_retries": 3
  }
}
