{
    "primary_model": "local",
    "models": {
        "local": {
            "provider": "openai-compatible",
            "baseUrl": "http://localhost:11434/v1",
            "model": "luna-v6-soul",
            "apiKey": "ollama",
            "temperature": 0.4,
            "maxTokens": 8192,
            "contextWindow": 128000
        }
    },
    "defaultModel": "luna-v6-soul",
    "routing": {
        "strategy": "local-first",
        "prefer_local": true
    },
    "fallback": {
        "enabled": true,
        "model": "Gemini 3.1-pro-High",
        "trigger": [
            "error",
            "context_exceeded",
            "timeout"
        ]
    }
}